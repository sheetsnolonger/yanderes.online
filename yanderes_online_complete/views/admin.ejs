<!DOCTYPE html>
<html>
<head>
<title>admin</title>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="stylesheet" href="/css/style.css">

</head>
<body>

<div class="shell">

<div class="site-header">
<div>
<h1>admin panel</h1>
<p class="tag">manage archive entries</p>
</div>

<nav>
<a href="/">archive</a>
<a href="/submit">submit</a>
<a href="/logout">logout</a>
</nav>
</div>

<% posts.forEach(post => { %>

<div class="post <%= post.pinned ? 'pinned' : '' %>">

<h2>#<%= post.id %> — <%= post.title %></h2>

<p class="tag">
<%= post.tag %>
<% if (post.pinned) { %> • pinned <% } %>
</p>

<pre><%= post.content.substring(0, 400) %></pre>

<div class="admin-actions">

<form action="/pin/<%= post.id %>" method="POST">
<button>
<%= post.pinned ? 'unpin' : 'pin' %>
</button>
</form>

<form action="/delete/<%= post.id %>" method="POST">
<button>delete</button>
</form>

<form action="/post/<%= post.id %>" method="GET">
<button>view</button>
</form>

</div>

</div>

<% }) %>

</div>

<div class="corner-img"></div>

</body>
</html>